# Vercel / local: copy to .env.local for `vercel dev` (never commit real keys).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# VAT protocol gate (/protocol/* rewrites).
# Passphrase is checked against POST /api/protocol-session (what users type in the app).
PROTOCOL_PASSPHRASE=diet
# Signing key for the unlock cookie — use a long random value on Vercel (e.g. openssl rand -hex 32).
PROTOCOL_COOKIE_SECRET=
